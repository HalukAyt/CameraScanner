{
  "expo": {
    "name": "CameraScanner",
    "slug": "CameraScanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ITECH.png",
    "scheme": "camerascanner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halukayt.CameraScanner",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "tr",
        "CFBundleLocalizations": ["tr"],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "CameraScanner, belgelerinizi taramak ve dijitalleştirmek için kameranıza erişim ister.",
        "NSPhotoLibraryUsageDescription": "Galerinizdeki mevcut belgeleri seçip tarayabilmeniz için fotoğraf kütüphanenize erişim gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "Taranan belgeleri galerinize kaydedebilmeniz için fotoğraf kütüphanesine yazma izni gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/ITECH.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/ITECH.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.halukayt.CameraScanner"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ITECH.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "react-native-document-scanner-plugin",
      [
        "expo-camera",
        {
          "cameraPermission": "CameraScanner uygulaması belgelerinizi taramak için kameranıza ihtiyaç duyar."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7283360706215445~8376099567",
          "iosAppId": "ca-app-pub-7283360706215445~1388019381"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f6e54d4-7205-40ef-9eaa-c11db19447f9"
      }
    }
  }
}
